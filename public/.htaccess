# Apache config for static-exported Next.js sites.
# Works out-of-the-box on One.com, Loopia, Oderland, Binero, Crystone etc.

# Force HTTPS (uncomment after you have an SSL cert set up):
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Pretty URLs: if /foo is requested and /foo/index.html exists, serve it.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect /foo to /foo/ (keeps trailing-slash setup consistent)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !(\.[a-zA-Z0-9]+)$
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ /$1/ [L,R=301]

  # Serve /foo/ from /foo/index.html
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^ %{REQUEST_URI}index.html [L]
</IfModule>

# Correct MIME type for the generated RSS feed.
<IfModule mod_mime.c>
  AddType application/rss+xml .xml
</IfModule>

# Cache static assets aggressively (they are fingerprinted by Next.js).
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml application/rss+xml
</IfModule>

# Custom 404 page generated by Next.js
ErrorDocument 404 /404.html
